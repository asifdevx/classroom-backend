{
    "compilerOptions": {
      "target": "es2017",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
     "rootDir": "./src",
    "outDir": "./dist",
       "typeRoots": ["./src/types", "./node_modules/@types"],
      "resolveJsonModule": true,
      "sourceMap": true,
      "noImplicitAny": true,
      "skipLibCheck": true
    },
"include": ["src/**/*.ts", "src/**/*.d.ts","axios"]
  }
  